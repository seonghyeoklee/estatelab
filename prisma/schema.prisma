generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── 회원 ────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  passwordHash  String    @map("password_hash")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  watchlist     UserWatchlist[]
  history       UserHistory[]
  settings      UserSettings?

  @@map("users")
}

model UserWatchlist {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  complexId   String   @map("complex_id")
  createdAt   DateTime @default(now()) @map("created_at")

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  complex ApartmentComplex @relation(fields: [complexId], references: [id], onDelete: Cascade)

  @@unique([userId, complexId])
  @@index([userId])
  @@map("user_watchlist")
}

model UserHistory {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  complexId   String   @map("complex_id")
  viewedAt    DateTime @default(now()) @map("viewed_at")

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  complex ApartmentComplex @relation(fields: [complexId], references: [id], onDelete: Cascade)

  @@unique([userId, complexId])
  @@index([userId, viewedAt])
  @@map("user_history")
}

model UserSettings {
  id          String   @id @default(cuid())
  userId      String   @unique @map("user_id")
  regionCodes String[] @default([]) @map("region_codes")  // 맞춤 지역 코드
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// ─── 법정동코드 ──────────────────────────────────────────────

model Region {
  id          String   @id @default(cuid())
  code        String   @unique              // 법정동코드 5자리 (11110, 11140 등)
  sido        String                        // 시도 (서울특별시)
  sigungu     String                        // 시군구 (종로구)
  fullName    String   @map("full_name")    // "서울특별시 종로구"
  createdAt   DateTime @default(now()) @map("created_at")

  complexes   ApartmentComplex[]

  @@index([sido])
  @@index([sigungu])
  @@map("regions")
}

// ─── 아파트 단지 ─────────────────────────────────────────────

model ApartmentComplex {
  id            String   @id @default(cuid())
  regionCode    String   @map("region_code")    // 법정동코드 5자리
  name          String                          // 단지명 (래미안)
  dong          String   @default("")              // 법정동 (사직동)
  jibun         String   @default("")              // 지번
  roadAddress   String?  @map("road_address")   // 도로명주소
  totalUnits    Int?     @map("total_units")    // 총 세대수
  builtYear     Int?     @map("built_year")     // 건축년도
  lat           Float?                          // 위도
  lng           Float?                          // 경도
  bjdongCd      String?  @map("bjdong_cd")      // 법정동코드 뒤 5자리 (건축물대장용)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  region        Region @relation(fields: [regionCode], references: [code])
  trades        ApartmentTrade[]
  rents         ApartmentRent[]
  watchedBy     UserWatchlist[]
  viewedBy      UserHistory[]

  @@unique([regionCode, name, dong, jibun])
  @@index([regionCode])
  @@index([name])
  @@map("apartment_complexes")
}

// ─── 아파트 실거래가 ─────────────────────────────────────────

model ApartmentTrade {
  id              String   @id @default(cuid())
  complexId       String   @map("complex_id")
  dealYear        Int      @map("deal_year")        // 거래년도
  dealMonth       Int      @map("deal_month")       // 거래월
  dealDay         Int      @map("deal_day")          // 거래일
  dealDate        DateTime @map("deal_date") @db.Date // 거래일자 (YYYY-MM-DD)
  area            Float                              // 전용면적 (㎡)
  floor           Int                                // 층
  price           Int                                // 거래금액 (만원)
  pricePerPyeong  Float?   @map("price_per_pyeong") // 평당가 (만원)
  dealType        String?  @map("deal_type")         // 중개거래, 직거래
  canceledAt      String?  @map("canceled_at")       // 해제사유발생일
  registeredAt    String?  @map("registered_at")     // 등기일자
  createdAt       DateTime @default(now()) @map("created_at")

  complex         ApartmentComplex @relation(fields: [complexId], references: [id], onDelete: Cascade)

  @@unique([complexId, dealDate, area, floor, price])
  @@index([complexId])
  @@index([dealDate])
  @@index([complexId, dealDate])
  @@index([dealDate, price])
  @@map("apartment_trades")
}

// ─── 아파트 전월세 ───────────────────────────────────────────

model ApartmentRent {
  id              String   @id @default(cuid())
  complexId       String   @map("complex_id")
  dealYear        Int      @map("deal_year")
  dealMonth       Int      @map("deal_month")
  dealDay         Int      @map("deal_day")
  dealDate        DateTime @map("deal_date") @db.Date
  area            Float                              // 전용면적 (㎡)
  floor           Int                                // 층
  rentType        String   @map("rent_type")         // 전세 | 월세
  deposit         Int                                // 보증금 (만원)
  monthlyRent     Int      @default(0) @map("monthly_rent") // 월세 (만원, 전세면 0)
  prevDeposit     Int?     @map("prev_deposit")      // 종전 보증금
  prevMonthlyRent Int?     @map("prev_monthly_rent") // 종전 월세
  contractTerm    String?  @map("contract_term")     // 계약기간
  contractType    String?  @map("contract_type")     // 신규 | 갱신
  createdAt       DateTime @default(now()) @map("created_at")

  complex         ApartmentComplex @relation(fields: [complexId], references: [id], onDelete: Cascade)

  @@unique([complexId, dealDate, area, floor, deposit, monthlyRent])
  @@index([complexId])
  @@index([dealDate])
  @@index([complexId, dealDate])
  @@index([rentType])
  @@map("apartment_rents")
}

// ─── 금리 ────────────────────────────────────────────────────

model InterestRate {
  id        String   @id @default(cuid())
  name      String                          // BASE_RATE, CD_91D, MORTGAGE_MIXED, MORTGAGE_FIXED
  nameKr    String?  @map("name_kr")        // 기준금리, CD금리(91일), 주담대(혼합), 주담대(고정)
  date      DateTime @db.Date
  rate      Float                           // 금리 (%)
  change    Float    @default(0)            // 전기대비 변동 (bp)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([name, date])
  @@index([name])
  @@index([date])
  @@map("interest_rates")
}

// ─── 가격지수 (한국부동산원) ─────────────────────────────────

model PriceIndex {
  id          String   @id @default(cuid())
  region      String                          // 서울, 경기, 인천, 전국 등
  indexType   String   @map("index_type")     // SALE (매매), LEASE (전세)
  date        DateTime @db.Date
  value       Float                           // 지수값
  changePct   Float    @default(0) @map("change_pct") // 전주/전월 대비 변동률 (%)
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([region, indexType, date])
  @@index([region, indexType])
  @@index([date])
  @@map("price_indices")
}

// ─── 알림 로그 ───────────────────────────────────────────────

model Alert {
  id        String   @id @default(cuid())
  type      String                            // TRADE_SURGE, RATE_CHANGE, SUBSCRIPTION 등
  title     String
  message   String
  metadata  Json?
  sentAt    DateTime? @map("sent_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([type])
  @@index([createdAt])
  @@map("alerts")
}

// ─── Cron 실행 로그 ─────────────────────────────────────────

model CronExecutionLog {
  id          String   @id @default(cuid())
  endpoint    String
  status      String                          // "success" | "partial" | "error"
  duration    Int                             // ms
  recordCount Int?     @map("record_count")
  errorCount  Int?     @map("error_count")
  detail      Json?
  triggeredBy String   @default("cron") @map("triggered_by")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([endpoint, createdAt])
  @@index([createdAt])
  @@map("cron_execution_logs")
}
