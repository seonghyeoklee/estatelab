# Neon (Vercel Marketplace — vercel integration add neon)
DATABASE_URL=postgresql://...          # pooled (애플리케이션용)
DATABASE_URL_UNPOOLED=postgresql://...  # unpooled (마이그레이션용)

# 공공데이터포털 (data.go.kr)
PUBLIC_DATA_API_KEY=

# 카카오 (developers.kakao.com)
NEXT_PUBLIC_KAKAO_APP_KEY=         # JavaScript 키 (지도)
KAKAO_REST_API_KEY=                # REST API 키 (지오코딩)

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Cron 인증
CRON_SECRET=

# AI
ANTHROPIC_API_KEY=
